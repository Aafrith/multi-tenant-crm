# ============================================================
# Backend environment variables — copy to .env and fill in
# ============================================================

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# Leave DB_NAME blank to use SQLite for local development
DB_NAME=crm_db
DB_USER=postgres
DB_PASS=your-db-password
DB_HOST=localhost
DB_PORT=5432

# JWT token lifetimes
JWT_ACCESS_HOURS=24
JWT_REFRESH_DAYS=7

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# AWS S3 (for logo uploads — leave blank to use local file storage)
# Strategy: public bucket with AWS_QUERYSTRING_AUTH=False
# Files are served through the bucket URL directly (no signed URLs needed
# for logos since they are not sensitive). In production use a private bucket
# with presigned URLs and set AWS_QUERYSTRING_AUTH=True.
AWS_KEY=your-aws-access-key-id
AWS_SECRET=your-aws-secret-access-key
AWS_BUCKET=your-s3-bucket-name
AWS_REGION=ap-south-1
